// Tier-2 Permission Approval (spawned_mode: "ask")
// An unattended spawn can't show a local permission prompt — it would hang the
// pane. The PreToolUse hook routes the decision to the topic as tappable buttons
// and blocks until you answer (or auto-denies). Only fires for spawned sessions.
//
// Render: dot -Tsvg permission-approval.dot -o permission-approval.svg

digraph permission_approval {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#f5f5f5"];
    edge [fontname="Helvetica", fontsize=9];

    tool   [label="spawned session calls a gated tool\nWrite / Edit / NotebookEdit / WebFetch /\nnon-allowlisted mcp__*"];
    hook   [label="PreToolUse: telegram-permission-hook.py\n(gated on TELEGRAM_BRIDGE_SPAWNED=1)", fillcolor="#fffde7"];

    spawned[label="spawned session?", shape=diamond, fillcolor="#fffde7"];
    allowl [label="MCP tool allowlisted in\nsettings.json / .local.json?", shape=diamond, fillcolor="#fffde7"];
    noop   [label="no-op: instant exit 0\n(normal sessions never prompt)", fillcolor="#e6f4ea"];
    autoallow[label="hook returns allow itself\n(skips native prompt)", fillcolor="#e6f4ea"];

    post   [label="post preview to topic\nwith Approve / Deny buttons", fillcolor="#e8f0fe", color="#1a73e8"];
    block  [label="hook BLOCKS\n(auto-deny after 240s)"];
    tap    [label="you tap a button\n(or type y / n)"];
    cb     [label="router: callback_query →\nsynthetic y/n line into inbox"];
    consume[label="hook consumes the line\n(like a typed reply)"];

    decide [label="approved?", shape=diamond, fillcolor="#fffde7"];
    allow  [label="allow → tool runs", fillcolor="#e6f4ea"];
    deny   [label="deny → tool blocked", fillcolor="#ffe0e0"];

    tool -> hook -> spawned;
    spawned -> noop      [label="no"];
    spawned -> allowl    [label="yes"];
    allowl -> autoallow  [label="yes"];
    allowl -> post       [label="no"];
    post -> block -> tap -> cb -> consume -> decide;
    decide -> allow [label="yes"];
    decide -> deny  [label="no / timeout"];
}

// System Architecture
// The smart-router / dumb-session topology: the phone, the one router daemon
// (the Massive) that owns all timing, the sessions it routes to (Invaders), and
// the out-of-band watchdog. Zim vocabulary matches the README.
//
// Render: dot -Tsvg system-architecture.dot -o system-architecture.svg

digraph system_architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#f5f5f5"];
    edge [fontname="Helvetica", fontsize=9];
    compound=true;

    subgraph cluster_orbit {
        label="The Tallest — your phone";
        style=filled;
        color="#e8f0fe";
        fillcolor="#f8faff";

        TOPIC [label="Telegram forum topic\n(one per session, like tabs)"];
    }

    TG [label="Telegram Bot API\ngetUpdates (single-consumer)", shape=cylinder, fillcolor="#ede7f6"];

    subgraph cluster_massive {
        label="The Massive — telegram-router.py (launchd)";
        style=filled;
        color="#fff9c4";
        fillcolor="#fffde7";

        ROUTER  [label="router loop\nsole getUpdates reader\nroute by message_thread_id"];
        CTX     [label="context_loop thread\ngauge · compaction trigger ·\nundrained backstop"];
    }

    subgraph cluster_planet {
        label="Invaders — Claude Code sessions (one per repo / dir)";
        style=filled;
        color="#fce8e6";
        fillcolor="#fef6f5";

        INBOX   [label="inbox.jsonl", shape=note, fillcolor="#ffffff"];
        SESSION [label="live Claude session\nfull context · MCP · hooks\ndrains when nudged (no cron)"];
        STATUS  [label="status.json\n+ pinned sticky", shape=note, fillcolor="#ffffff"];
    }

    WATCHDOG [label="wedge watchdog\ntelegram-watchdog.py (launchd timer)\nalerts on stuck interactive prompts"];

    // Inbound transmission
    TOPIC -> TG          [label="you type"];
    TG -> ROUTER         [label="updates"];
    ROUTER -> INBOX      [label="route message"];
    ROUTER -> SESSION    [label="send-keys\ndrain nudge", style=dashed];

    // Session processing + reply
    INBOX -> SESSION     [label="drain (section A)"];
    SESSION -> TG        [label="telegram-send.sh", color="#1a73e8"];
    TG -> TOPIC          [label="reply", color="#1a73e8"];

    // Out-of-band timing, off the getUpdates path
    CTX -> STATUS        [label="compute gauge", style=dotted];
    CTX -> SESSION       [label="trigger /compact ·\nre-nudge undrained", style=dotted];
    STATUS -> ROUTER     [label="edit pin", style=dotted];

    // Safety net
    WATCHDOG -> SESSION  [label="scan tmux panes", style=dotted, color="#9e9e9e"];
    WATCHDOG -> TG       [label="⚠️ wedge alert", color="#9e9e9e"];
}

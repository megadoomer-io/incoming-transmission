# Runtime state — never committed (chat_id, offset, registry, logs, sessions)
__pycache__/
*.pyc
state/
*.log

# Local, personal config (ship the .example instead)
runtime/dir-aliases.json
runtime/telegram-auq-mcp.json
# Live lifecycle hooks (ship the .example.txt; live copies are user-edited)
runtime/lifecycle/*.txt
!runtime/lifecycle/*.example.txt

# Rendered launchd plists (generated by install.sh from the templates)
*.plist.rendered

# Secrets
.env
*.token

# Dev test tooling (uv venv + pytest cache)
.venv/
.pytest_cache/
